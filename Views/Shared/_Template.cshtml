<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ហាងទំនិញអនឡាញ</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2 family=Kantumruuy+Pro:wght@300;400;600&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-store-color: #ff9f43; /* ពណ៌ចម្បងបែប E-commerce (លឿងទុំ) */
            --dark-store-color: #1e272e;    /* ពណ៌កាត់ខ្មៅក្រម៉ៅ */
        }

        body {
            font-family: 'Poppins', 'Kantumruuy Pro', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #f1f2f6;
        }
        .main-content {
            flex: 1;
        }
        .navbar-brand {
            font-weight: 600;
            letter-spacing: 1px;
        }
        .text-store-primary {
            color: var(--primary-store-color) !important;
        }
        .bg-store-dark {
            background-color: var(--dark-store-color) !important;
        }
        .btn-store {
            background-color: var(--primary-store-color);
            color: white;
            border: none;
            transition: all 0.3s ease;
        }
        .btn-store:hover {
            background-color: #f39c12;
            color: white;
            transform: translateY(-2px);
        }
        
        /* Product Card Interface Styles */
        .product-card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
            transition: all 0.3s ease;
            background: #fff;
        }
        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
        .product-img-container {
            position: relative;
            background-color: #f9f9f9;
            height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .product-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background-color: #ff4757;
            color: white;
            padding: 4px 10px;
            font-size: 12px;
            border-radius: 20px;
            font-weight: 600;
        }
        .wishlist-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            background: white;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            color: #ff4757;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            transition: all 0.2s;
        }
        .wishlist-btn:hover {
            transform: scale(1.1);
        }
        
        .footer {
            background-color: var(--dark-store-color);
            color: #ced6e0;
        }
        .footer a {
            color: #ced6e0;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .footer a:hover {
            color: var(--primary-store-color);
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-store-dark shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand text-store-primary" href="@Url.Action("Index", "Home")">
                <i class="fa-solid fa-bag-shopping me-2"></i>Mart<span class="text-white">Space</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="@Url.Action("Index", "Home")"><i class="fa-solid fa-house me-1"></i> ទំព័រដើម</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fa-solid fa-boxes-stacked me-1"></i> ផលិតផលទាំងអស់</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fa-solid fa-tags me-1"></i> ប្រូម៉ូសិនពិសេស</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fa-solid fa-phone me-1"></i> ទំនាក់ទំនង</a>
                    </li>
                </ul>
                
                <div class="ms-lg-3 d-flex align-items-center gap-3">
                    <a href="#" class="text-white position-relative fs-5 me-2">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 10px;">
                            3
                        </span>
                    </a>
                    <a href="#" class="btn btn-store rounded-pill px-4 shadow-sm">ចូលប្រព័ន្ធ</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container main-content my-5">
        
        <div>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0 text-dark"><i class="fa-solid fa-fire text-danger me-2"></i>ផលិតផលពេញនិយម</h3>
                <a href="#" class="text-store-primary text-decoration-none fw-bold">មើលទាំងអស់ <i class="fa-solid fa-arrow-right"></i></a>
            </div>

            <div class="row g-4">
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 shadow-sm">
                        <div class="product-img-container">
                            <span class="product-badge">បញ្ចុះតម្លៃ</span>
                            <button class="wishlist-btn"><i class="fa-regular fa-heart"></i></button>
                            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400" class="img-fluid p-3" alt="Product" style="max-height: 180px; object-fit: contain;">
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <span class="text-muted small mb-1">ស្បែកជើង</span>
                            <h6 class="card-title text-dark fw-bold text-truncate mb-2">ស្បែកជើងកីឡាទំនើប Max-2026</h6>
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="text-danger fw-bold fs-5">$45.00</span>
                                <span class="text-muted text-decoration-line-through small">$60.00</span>
                            </div>
                            <button class="btn btn-store w-100 mt-auto rounded-3"><i class="fa-solid fa-cart-plus me-2"></i>ដាក់ក្នុងកន្ត្រក</button>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 shadow-sm">
                        <div class="product-img-container">
                            <button class="wishlist-btn"><i class="fa-regular fa-heart"></i></button>
                            <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400" class="img-fluid p-3" alt="Product" style="max-height: 180px; object-fit: contain;">
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <span class="text-muted small mb-1">គ្រឿងអេឡិចត្រូនិច</span>
                            <h6 class="card-title text-dark fw-bold text-truncate mb-2">កាសស្តាប់ត្រចៀក Bluetooth Premium</h6>
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="text-dark fw-bold fs-5">$89.00</span>
                            </div>
                            <button class="btn btn-store w-100 mt-auto rounded-3"><i class="fa-solid fa-cart-plus me-2"></i>ដាក់ក្នុងកន្ត្រក</button>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 shadow-sm">
                        <div class="product-img-container">
                            <span class="product-badge bg-success">ថ្មី</span>
                            <button class="wishlist-btn"><i class="fa-regular fa-heart"></i></button>
                            <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400" class="img-fluid p-3" alt="Product" style="max-height: 180px; object-fit: contain;">
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <span class="text-muted small mb-1">នាឡិកាដៃ</span>
                            <h6 class="card-title text-dark fw-bold text-truncate mb-2">នាឡិកាដៃឆ្លាតវៃ Smart Watch Series 5</h6>
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="text-dark fw-bold fs-5">$120.00</span>
                            </div>
                            <button class="btn btn-store w-100 mt-auto rounded-3"><i class="fa-solid fa-cart-plus me-2"></i>ដាក់ក្នុងកន្ត្រក</button>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 shadow-sm">
                        <div class="product-img-container">
                            <button class="wishlist-btn"><i class="fa-regular fa-heart"></i></button>
                            <img src="https://images.unsplash.com/photo-1583394838336-acd977736f90?w=400" class="img-fluid p-3" alt="Product" style="max-height: 180px; object-fit: contain;">
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <span class="text-muted small mb-1">គ្រឿងអេឡិចត្រូនិច</span>
                            <h6 class="card-title text-dark fw-bold text-truncate mb-2">កាសខ្សែកម្រិតសំឡេងបុកបាសខ្លាំង</h6>
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="text-danger fw-bold fs-5">$15.00</span>
                                <span class="text-muted text-decoration-line-through small">$25.00</span>
                            </div>
                            <button class="btn btn-store w-100 mt-auto rounded-3"><i class="fa-solid fa-cart-plus me-2"></i>ដាក់ក្នុងកន្ត្រក</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* បើប្រើក្នុង ASP.NET MVC ពិតប្រាកដ សូមលុបការរៀបរាប់ Product ខាងលើចេញ ហើយទុកតែដង្កៀបខាងក្រោមនេះ *@
        @* @RenderBody() *@
        
    </div>

    <footer class="footer pt-5 pb-4 mt-auto">
        <div class="container">
            <div class="row text-center text-md-start">
                <div class="col-md-4 col-lg-4 col-xl-3 mx-auto mb-4">
                    <h5 class="text-uppercase fw-bold text-white mb-4">
                        <i class="fa-solid fa-bag-shopping text-store-primary me-2"></i>MartSpace
                    </h5>
                    <p>យើងខ្ញុំផ្តល់ជូននូវទំនិញដែលមានគុណភាពខ្ពស់ តម្លៃសមរម្យ និងសេវាកម្មដឹកជញ្ជូនរហ័សទាន់ចិត្ត។</p>
                </div>
                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mb-4">
                    <h6 class="text-uppercase fw-bold text-white mb-4">ផ្នែកពេញនិយម</h6>
                    <p><a href="#!">គ្រឿងអេឡិចត្រូនិច</a></p>
                    <p><a href="#!">សម្លៀកបំពាក់</a></p>
                    <p><a href="#!">ស្បែកជើងកីឡា</a></p>
                </div>
                <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mb-md-0 mb-4">
                    <h6 class="text-uppercase fw-bold text-white mb-4">ព័ត៌មានទំនាក់ទំនង</h6>
                    <p><i class="fas fa-home me-3 text-store-primary"></i> ភ្នំពេញ, កម្ពុជា</p>
                    <p><i class="fas fa-envelope me-3 text-store-primary"></i> support@martspace.com</p>
                    <p><i class="fas fa-phone me-3 text-store-primary"></i> +855 99 999 999</p>
                </div>
            </div>
            <hr class="bg-light my-4">
            <div class="row align-items-center">
                <div class="col-md-7 col-lg-8 text-center text-md-start">
                    <p class="mb-0">© 2026 រក្សាសិទ្ធិគ្រប់យ៉ាងដោយ: <a class="text-store-primary fw-bold" href="#">MartSpace</a></p>
                </div>
                <div class="col-md-5 col-lg-4 text-center text-md-end">
                    <ul class="list-unstyled list-inline mb-0">
                        <li class="list-inline-item"><a href="#" class="btn-floating btn-sm text-white" style="font-size: 23px;"><i class="fab fa-facebook text-primary"></i></a></li>
                        <li class="list-inline-item"><a href="#" class="btn-floating btn-sm text-white" style="font-size: 23px;"><i class="fab fa-instagram text-danger"></i></a></li>
                        <li class="list-inline-item"><a href="#" class="btn-floating btn-sm text-white" style="font-size: 23px;"><i class="fab fa-telegram text-info"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>