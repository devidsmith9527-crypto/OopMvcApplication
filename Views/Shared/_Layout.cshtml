<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApp</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Kantumruuy+Pro:wght@300;400;600&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', 'Kantumruuy Pro', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
        .main-content {
            flex: 1;
        }
        .navbar-brand {
            font-weight: 600;
            letter-spacing: 1px;
        }
        .nav-link {
            font-weight: 500;
            transition: color 0.3s ease;
        }
        .footer {
            background-color: #212529;
            color: #aeb4b9;
        }
        .footer a {
            color: #aeb4b9;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .footer a:hover {
            color: #fff;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand text-primary" href="@Url.Action("Index", "Home")">
                <i class="fa-solid fa-code me-2"></i>Dev<span class="text-white">Space</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="@Url.Action("Index", "Home")"><i class="fa-solid fa-house me-1"></i> ទំព័រដើម</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fa-solid fa-layer-group me-1"></i> សេវាកម្ម</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fa-solid fa-briefcase me-1"></i> គម្រោង</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"><i class="fa-solid fa-envelope me-1"></i> ទំនាក់ទំនង</a>
                    </li>
                </ul>
                <div class="ms-lg-3">
                    <a href="#" class="btn btn-primary rounded-pill px-4 shadow-sm">ចូលប្រព័ន្ធ</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container main-content my-5">
        @RenderBody()
    </div>

    <footer class="footer pt-5 pb-4 mt-auto">
        <div class="container">
            <div class="row text-center text-md-start">
                <div class="col-md-4 col-lg-4 col-xl-3 mx-auto mb-4">
                    <h5 class="text-uppercase fw-bold text-white mb-4">
                        <i class="fa-solid fa-code text-primary me-2"></i>DevSpace
                    </h5>
                    <p>យើងបង្កើតដំណោះស្រាយបច្ចេកវិទ្យាដ៏មានប្រសិទ្ធភាព និងទំនើបបំផុតសម្រាប់អាជីវកម្មរបស់អ្នក។</p>
                </div>
                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mb-4">
                    <h6 class="text-uppercase fw-bold text-white mb-4">តំណភ្ជាប់រហ័ស</h6>
                    <p><a href="#!">អំពីយើង</a></p>
                    <p><a href="#!">ប្លុក</a></p>
                    <p><a href="#!">ជំនួយ</a></p>
                </div>
                <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mb-md-0 mb-4">
                    <h6 class="text-uppercase fw-bold text-white mb-4">ព័ត៌មានទំនាក់ទំនង</h6>
                    <p><i class="fas fa-home me-3 text-primary"></i> ភ្នំពេញ, កម្ពុជា</p>
                    <p><i class="fas fa-envelope me-3 text-primary"></i> info@example.com</p>
                    <p><i class="fas fa-phone me-3 text-primary"></i> +855 12 345 678</p>
                </div>
            </div>
            <hr class="bg-white my-4">
            <div class="row align-items-center">
                <div class="col-md-7 col-lg-8 text-center text-md-start">
                    <p class="mb-0">© 2026 រក្សាសិទ្ធិគ្រប់យ៉ាងដោយ: <a class="text-primary fw-bold" href="#">DevSpace</a></p>
                </div>
                <div class="col-md-5 col-lg-4 text-center text-md-end">
                    <ul class="list-unstyled list-inline mb-0">
                        <li class="list-inline-item"><a href="#" class="btn-floating btn-sm text-white" style="font-size: 23px;"><i class="fab fa-facebook"></i></a></li>
                        <li class="list-inline-item"><a href="#" class="btn-floating btn-sm text-white" style="font-size: 23px;"><i class="fab fa-twitter"></i></a></li>
                        <li class="list-inline-item"><a href="#" class="btn-floating btn-sm text-white" style="font-size: 23px;"><i class="fab fa-linkedin-in"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>