@model IEnumerable<OopMvcApplication.Models.Student>
<div class="container mt-4">
    <h2 class="text-primary">បញ្ជីឈ្មោះនិស្សិត</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>ឈ្មោះ</th>
                <th>ជំនាញ</th>
                <th>Telegram</th>
                <th>ថ្ងៃខែឆ្នាំកំណើត</th>
                <th>អ៊ីមែល</th>
                <th>សកម្មភាព</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model) {
                <tr>
                    <td>@student.Id</td>
                    <td>@student.Name</td>
                    <td>@student.Major</td>
                    <td>@student.Telegram</td>
                    <td>@student.DateOfBirth.ToString("yyyy-MM-dd")</td>
                    <td>@student.Email</td>
                    <td>
                        <a href="/Students/Details/@student.Id" class="btn btn-sm btn-info">លំអិត</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>